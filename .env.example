# ── Anthropic ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Stripe ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe Price IDs (create these in your Stripe dashboard)
STRIPE_PRICE_PRO=price_your-pro-monthly-price-id
STRIPE_PRICE_TEAMS=price_your-teams-monthly-price-id

# ── Auth ───────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# ── App ────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── Database ───────────────────────────────────────
# LandIt uses a simple JSON file DB for easy deployment.
# Swap this for PostgreSQL/MongoDB in production by updating db.js
DB_PATH=./data/users.json
